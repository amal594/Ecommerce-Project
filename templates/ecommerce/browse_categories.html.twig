{% extends 'base.html.twig' %}

{% block title %}Browse Categories - Our Store{% endblock %}

{% block body %}
    <div class="container my-5">
        <h1 class="mb-4">Browse Categories</h1>

        {% if categories is empty %}
            <p class="text-muted">No categories available yet.</p>
        {% else %}
            <div class="row row-cols-1 row-cols-md-3 g-4">
                {% for category in categories %}
                    <div class="col">
                        <div class="card h-100 text-center">
                            <div class="card-body">
                                <span class="badge bg-primary mb-3">
                                    {{ category.products|length }} products
                                </span>
                                {% if category.imageUrl %}
                                    <img
                                        src="{{ category.imageUrl }}"
                                        alt="{{ category.name }}"
                                        style="width: 100%; height: 140px; object-fit: cover;"
                                        class="mb-3 rounded"
                                    >
                                {% endif %}
                                <h5 class="card-title">{{ category.name }}</h5>
                                <a href="{{ path('app_products_by_category', {id: category.id}) }}" class="btn btn-outline-primary">View Products</a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
